+const triedPoolKeys = new Set<string>()
+
+function getServerBase(): string {
+  if (typeof window !== "undefined" && window.location) {
+    return window.location.origin
+  }
+  return "http://localhost:4096"
+}
+
+async function listPoolEntries(provider: string): Promise<Array<{ key: string; label?: string }>> {
+  try {
+    const base = getServerBase()
+    const res = await fetch(`${base}/auth/${encodeURIComponent(provider)}/pool`)
+    if (!res.ok) return []
+    return await res.json()
+  } catch {
+    return []
+  }
+}
+
+async function switchPoolKey(provider: string, index: number): Promise<boolean> {
+  try {
+    const base = getServerBase()
+    const res = await fetch(`${base}/auth/${encodeURIComponent(provider)}/pool/switch/${index}`, {
+      method: "POST",
+    })
+    return res.ok
+  } catch {
+    return false
+  }
+}
+
+function notifySystemMessage(title: string, description: string) {
+  try {
+    if (typeof Notification !== "undefined" && Notification.permission === "granted") {
+      new Notification(title, { body: description })
+    }
+  } catch {
+  }
+}
