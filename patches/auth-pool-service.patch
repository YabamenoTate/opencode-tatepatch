+import path from "path"
+import { Effect, Layer, Schema, Context } from "effect"
+import { Global } from "@opencode-ai/core/global"
+import { AppFileSystem } from "@opencode-ai/core/filesystem"
+import { Auth } from "."
+
+const POOL_FILE = path.join(Global.Path.data, "auth-pool.json")
+
+export class PoolSchema extends Schema.Class<PoolSchema>("AuthPoolEntry")({
+  key: Schema.String,
+  label: Schema.optional(Schema.String),
+}) {}
+
+export type PoolEntry = Schema.Schema.Type<typeof PoolSchema>
+
+export interface Interface {
+  readonly list: (providerID: string) => Effect.Effect<PoolEntry[], never>
+  readonly add: (providerID: string, entry: PoolEntry) => Effect.Effect<void, never>
+  readonly remove: (providerID: string, index: number) => Effect.Effect<void, never>
+  readonly switch: (providerID: string, index: number) => Effect.Effect<void, never>
+  readonly count: (providerID: string) => Effect.Effect<number, never>
+}
+
+export const Service: Context.Service<Interface, Interface> = Context.Service("@opencode/AuthPool")
+
+const rawPool = (fsys: AppFileSystem.Service) =>
+  Effect.fn("AuthPool.read")(function* () {
+    const data = (yield* fsys.readJson(POOL_FILE).pipe(Effect.orElseSucceed(() => ({})))) as Record<
+      string,
+      Array<{ key: string; label?: string }>
+    >
+    return data
+  })
+
+const writePool = (fsys: AppFileSystem.Service, data: Record<string, Array<{ key: string; label?: string }>>) =>
+  fsys.writeJson(POOL_FILE, data, 0o600).pipe(Effect.orDie)
+
+export const layer = Layer.effect(
+  Service,
+  Effect.gen(function* () {
+    const fsys = yield* AppFileSystem.Service
+
+    const list = Effect.fn("AuthPool.list")(function* (providerID: string) {
+      const data = yield* rawPool(fsys)
+      return (data[providerID] ?? []) as PoolEntry[]
+    })
+
+    const add = Effect.fn("AuthPool.add")(function* (providerID: string, entry: PoolEntry) {
+      const data = yield* rawPool(fsys)
+      if (!data[providerID]) data[providerID] = []
+      data[providerID].push(entry)
+      yield* writePool(fsys, data)
+    })
+
+    const remove = Effect.fn("AuthPool.remove")(function* (providerID: string, index: number) {
+      const data = yield* rawPool(fsys)
+      const arr = data[providerID]
+      if (!arr || index < 0 || index >= arr.length) return
+      arr.splice(index, 1)
+      if (arr.length === 0) delete data[providerID]
+      yield* writePool(fsys, data)
+    })
+
+    const switch_ = Effect.fn("AuthPool.switch")(function* (providerID: string, index: number) {
+      const data = yield* rawPool(fsys)
+      const arr = data[providerID]
+      if (!arr || index < 0 || index >= arr.length) return
+
+      const poolEntry = arr[index]
+      const authService = yield* Auth.Service
+      const current = yield* authService.get(providerID)
+
+      const newMain: Auth.Info = { type: "api", key: poolEntry.key }
+      yield* authService.set(providerID, newMain)
+
+      if (current?.type === "api") {
+        arr[index] = { key: current.key }
+      } else {
+        arr.splice(index, 1)
+      }
+      if (arr.length === 0) delete data[providerID]
+      yield* writePool(fsys, data)
+    })
+
+    const count = Effect.fn("AuthPool.count")(function* (providerID: string) {
+      const data = yield* rawPool(fsys)
+      return (data[providerID] ?? []).length
+    })
+
+    return { list, add, remove, switch: switch_, count }
+  }),
+)
+
+export const defaultLayer = layer.pipe(Layer.provide(AppFileSystem.defaultLayer))
