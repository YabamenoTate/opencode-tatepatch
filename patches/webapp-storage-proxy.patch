@@ -0,0 +1,53 @@
+import { Effect } from "effect"
+import { HttpApiBuilder } from "effect/unstable/httpapi"
+import * as HttpServerResponse from "effect/unstable/http/HttpServerResponse"
+import { InstanceHttpApi } from "../api"
+import { AppFileSystem } from "@opencode-ai/core/filesystem"
+import { Path as GlobalPath } from "@opencode-ai/core/global"
+import path from "path"
+import { unlink } from "fs/promises"
+
+const PERSIST_DIR = "persist"
+
+function filePath(dir: string, key: string) {
+  const safe = (s: string) => s.replace(/[^a-zA-Z0-9._-]/g, "_")
+  return path.join(dir, PERSIST_DIR, safe(key)) + ".json"
+}
+
+export const persistHandlers = HttpApiBuilder.group(InstanceHttpApi, "persist", (handlers) =>
+  Effect.gen(function* () {
+    const fs = yield* AppFileSystem.Service
+    const dataDir = path.join(GlobalPath.data, "storage")
+
+    const get = Effect.fn("PersistHttpApi.get")(function* (ctx: {
+      params: { key: string }
+    }) {
+      const target = filePath(dataDir, ctx.params.key)
+      const content = yield* fs.readFileStringSafe(target)
+      if (content === undefined) {
+        return HttpServerResponse.text("", { status: 404 as const })
+      }
+      return HttpServerResponse.text(content, { contentType: "application/json" })
+    })
+
+    const set = Effect.fn("PersistHttpApi.set")(function* (ctx: {
+      params: { key: string }
+      payload: string
+    }) {
+      const target = filePath(dataDir, ctx.params.key)
+      yield* fs.writeWithDirs(target, ctx.payload)
+    })
+
+    const remove = Effect.fn("PersistHttpApi.remove")(function* (ctx: {
+      params: { key: string }
+    }) {
+      const target = filePath(dataDir, ctx.params.key)
+      yield* Effect.tryPromise(() => unlink(target)).pipe(Effect.catch(() => Effect.void))
+    })
+
+    return handlers
+      .handle("get", get)
+      .handle("set", set)
+      .handle("remove", remove)
+  }),
+)
