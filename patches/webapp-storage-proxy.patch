+// Intercept ALL localStorage — server-only XHR layer.
+// Every browser sees the same state since all data lives on the server.
+if (typeof localStorage !== "undefined") {
+  const orig = localStorage
+  Storage.prototype.getItem = function (key: string): string | null {
+    if (key == null) return null
+    try {
+      const xhr = new XMLHttpRequest()
+      xhr.open("GET", "/persist/" + encodeURIComponent(key), false)
+      xhr.send()
+      if (xhr.status === 200) return xhr.responseText
+    } catch { /* server down */ }
+    return null
+  }
+  Storage.prototype.setItem = function (key: string, value: string): void {
+    try {
+      const xhr = new XMLHttpRequest()
+      xhr.open("PUT", "/persist/" + encodeURIComponent(key), false)
+      xhr.setRequestHeader("Content-Type", "application/json")
+      xhr.send(JSON.stringify(value))
+    } catch { /* server down */ }
+  }
+  Storage.prototype.removeItem = function (key: string): void {
+    try {
+      const xhr = new XMLHttpRequest()
+      xhr.open("DELETE", "/persist/" + encodeURIComponent(key), false)
+      xhr.send()
+    } catch { /* server down */ }
+  }
+  Storage.prototype.clear = function (): void {
+    /* no-op */
+  }
+}
