diff --git a/packages/opencode/src/auth/pool.ts b/packages/opencode/src/auth/pool.ts
new file mode 100644
index 0000000..f913ec4
--- /dev/null
+++ b/packages/opencode/src/auth/pool.ts
@@ -0,0 +1,146 @@
+import path from "path"
+import { Effect, Layer, Schema, Context } from "effect"
+import { Global } from "@opencode-ai/core/global"
+import { AppFileSystem } from "@opencode-ai/core/filesystem"
+import { Auth } from "."
+
+const POOL_FILE = path.join(Global.Path.data, "auth-pool.json")
+
+export class PoolSchema extends Schema.Class<PoolSchema>("AuthPoolEntry")({
+  key: Schema.String,
+  label: Schema.optional(Schema.String),
+}) {}
+
+export type PoolEntry = Schema.Schema.Type<typeof PoolSchema>
+
+type PoolData = Record<string, unknown>
+
+export interface Interface {
+  readonly list: (providerID: string) => Effect.Effect<PoolEntry[], never>
+  readonly add: (providerID: string, entry: PoolEntry) => Effect.Effect<void, never>
+  readonly remove: (providerID: string, index: number) => Effect.Effect<void, never>
+  readonly switch: (providerID: string, index: number) => Effect.Effect<void, never>
+  readonly count: (providerID: string) => Effect.Effect<number, never>
+  readonly resetToMain: (providerID: string) => Effect.Effect<void, never>
+}
+
+export const Service: Context.Service<Interface, Interface> = Context.Service("@opencode/AuthPool")
+
+const getEntries = (data: PoolData, providerID: string): PoolEntry[] =>
+  Array.isArray(data[providerID]) ? (data[providerID] as PoolEntry[]) : []
+
+const getMain = (data: PoolData, providerID: string): string | undefined => {
+  const main = data._main
+  return typeof main === "object" && main !== null && !Array.isArray(main)
+    ? (main as Record<string, string>)[providerID]
+    : undefined
+}
+
+const rawPool = (fsys: AppFileSystem.Service) =>
+  fsys.readJson(POOL_FILE).pipe(
+    Effect.orElseSucceed(() => ({}) as PoolData),
+  )
+
+const writePool = (fsys: AppFileSystem.Service, data: PoolData) =>
+  fsys.writeJson(POOL_FILE, data, 0o600).pipe(Effect.orDie)
+
+export const layer = Layer.effect(
+  Service,
+  Effect.gen(function* () {
+    const fsys = yield* AppFileSystem.Service
+
+    const list = Effect.fn("AuthPool.list")(function* (providerID: string) {
+      const data = yield* rawPool(fsys)
+      return getEntries(data, providerID)
+    })
+
+    const add = Effect.fn("AuthPool.add")(function* (providerID: string, entry: PoolEntry) {
+      const data = yield* rawPool(fsys)
+      const arr = getEntries(data, providerID)
+      arr.push(entry)
+      data[providerID] = arr
+      yield* writePool(fsys, data)
+    })
+
+    const remove = Effect.fn("AuthPool.remove")(function* (providerID: string, index: number) {
+      const data = yield* rawPool(fsys)
+      const arr = getEntries(data, providerID)
+      if (index < 0 || index >= arr.length) return
+      arr.splice(index, 1)
+      if (arr.length === 0) {
+        delete data[providerID]
+      } else {
+        data[providerID] = arr
+      }
+      yield* writePool(fsys, data)
+    })
+
+    const switch_ = Effect.fn("AuthPool.switch")(function* (providerID: string, index: number) {
+      const data = yield* rawPool(fsys)
+      const arr = getEntries(data, providerID)
+      if (index < 0 || index >= arr.length) return
+
+      const poolEntry = arr[index]
+      const authService = yield* Auth.Service
+      const current = yield* authService.get(providerID)
+
+      if (current?.type === "api" && !getMain(data, providerID)) {
+        data._main = { ...((data._main as Record<string, string>) ?? {}), [providerID]: current.key }
+      }
+
+      const newMain: Auth.Info = { type: "api", key: poolEntry.key }
+      yield* authService.set(providerID, newMain)
+
+      if (current?.type === "api") {
+        arr[index] = { key: current.key }
+      } else {
+        arr.splice(index, 1)
+      }
+      if (arr.length === 0) {
+        delete data[providerID]
+      } else {
+        data[providerID] = arr
+      }
+      yield* writePool(fsys, data)
+    })
+
+    const count = Effect.fn("AuthPool.count")(function* (providerID: string) {
+      const data = yield* rawPool(fsys)
+      return getEntries(data, providerID).length
+    })
+
+    const resetToMain = Effect.fn("AuthPool.resetToMain")(function* (providerID: string) {
+      const data = yield* rawPool(fsys)
+      const mainKey = getMain(data, providerID)
+      if (!mainKey) return
+
+      const arr = getEntries(data, providerID)
+      const idx = arr.findIndex((e) => e.key === mainKey)
+      if (idx < 0) return
+
+      // Same swap logic as switch()
+      const authService = yield* Auth.Service
+      const current = yield* authService.get(providerID)
+      const newMain: Auth.Info = { type: "api", key: mainKey }
+      yield* authService.set(providerID, newMain)
+
+      if (current?.type === "api") {
+        arr[idx] = { key: current.key }
+      } else {
+        arr.splice(idx, 1)
+      }
+      if (arr.length === 0) {
+        delete data[providerID]
+      } else {
+        data[providerID] = arr
+      }
+      delete (data._main as Record<string, string>)[providerID]
+      if (Object.keys(data._main as Record<string, string>).length === 0) delete data._main
+      yield* writePool(fsys, data)
+    })
+
+    return { list, add, remove, switch: switch_, count, resetToMain }
+  }),
+)
+
+export const defaultLayer = layer.pipe(Layer.provide(AppFileSystem.defaultLayer))
